{
  "manifest_version": 3,
  "name": "AVS Cleaner",
  "version": "3.3",
  "author": "Lam",
  "description": "Dọn dẹp quảng cáo, chặn popup và tải video cho AnimeVietSub.",

  "permissions": [
    "alarms",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "*://*/*",
    "https://raw.githubusercontent.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "declarative_net_request": {
    "rule_resources": [{
      "id": "ruleset_1",
      "enabled": true,
      "path": "rules.json"
    }]
  },

  "web_accessible_resources": [{
    "resources": ["assets/logoz.png"],
    "matches": ["*://*/*"]
  }]
}
